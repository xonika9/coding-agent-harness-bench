# ============================================================================
# EDIT-ME. One bash function per column. Each runs in $PWD == the task clone,
# reads the task instruction from $PROMPT, and must run fully autonomously
# (no permission prompts). Claude columns also get a pinned $SID (session id).
# preflight.sh verifies each of these end-to-end on a trivial prompt.
#
# Adjust model slugs / effort flags to match how YOU actually invoke them.
# ============================================================================

# Col 1 — Codex, gpt-5.6-sol, medium (your incumbent)
launch_codex56 () {
  codex exec -C "$PWD" -m gpt-5.6-sol -c model_reasoning_effort=medium \
    --dangerously-bypass-approvals-and-sandbox --json "$PROMPT"
}

# Col 2 — CCX: Claude Code harness + gpt-5.6-sol via CLIProxyAPI, medium
# (reconstructed from your ccx alias; proxy must be up on :8318)
launch_ccx () {
  ANTHROPIC_BASE_URL=http://127.0.0.1:8318 ANTHROPIC_AUTH_TOKEN=dummy \
  ANTHROPIC_SMALL_FAST_MODEL=gpt-5.6-luna CLAUDE_CODE_SUBAGENT_MODEL=inherit \
  CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1 CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=3 \
  ENABLE_TOOL_SEARCH=false CLAUDE_CODE_AUTO_COMPACT_WINDOW=272000 \
  claude --settings "$HOME/.agents/runtime/claude-gpt.json" \
         --append-system-prompt-file "$HOME/.agents/runtime/claude-gpt-prompt.md" \
         --model gpt-5.6-sol --effort medium --dangerously-skip-permissions \
         -p "$PROMPT" --output-format json --session-id "$SID"
}

# Col 3 — native Claude Code, opus-4.8, xhigh (uses your Max, no proxy)
launch_ccopus () {
  claude --model claude-opus-4-8 --effort xhigh --dangerously-skip-permissions \
         -p "$PROMPT" --output-format json --session-id "$SID"
}

# Col 4 — Codex, gpt-5.5, high (your previous setup)
launch_codex55 () {
  codex exec -C "$PWD" -m gpt-5.5 -c model_reasoning_effort=high \
    --dangerously-bypass-approvals-and-sandbox --json "$PROMPT"
}
