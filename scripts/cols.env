# The four harness columns. Folder key -> human label.
COLS=(codex56 ccx ccopus codex55)
declare -A COL_LABEL=(
  [codex56]="Codex · gpt-5.6-sol · medium"
  [ccx]="Claude Code (CCX) · gpt-5.6-sol · medium"
  [ccopus]="Claude Code (native) · opus-4.8 · xhigh"
  [codex55]="Codex · gpt-5.5 · high"
)
# which cost path a column uses: "claude" (-p json) or "codex" (ccusage-codex)
declare -A COL_KIND=(
  [codex56]=codex [ccx]=claude [ccopus]=claude [codex55]=codex
)
TIMEOUT_SEC=1200   # per-run hard cutoff (20 min)
